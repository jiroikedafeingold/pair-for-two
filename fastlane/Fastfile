default_platform(:ios)

platform :ios do
  desc "Upload App Store metadata + screenshots (no binary) using an App Store Connect API key"
  lane :upload_store do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,     # binary is delivered by Xcode Cloud
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,     # you press submit in App Store Connect
      run_precheck_before_submit: false,
      force: true
    )
  end
end
